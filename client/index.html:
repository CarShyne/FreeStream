<!DOCTYPE html>
<html>
<head>
    <title>FreeStream</title>
    <style>
        body { background: #111; color: white; font-family: sans-serif; }
        .grid { display: flex; flex-wrap: wrap; gap: 10px; padding: 20px; }
        .item {
            width: 200px;
            padding: 20px;
            background: #222;
            cursor: pointer;
            text-align: center;
        }
        .item:hover { background: #444; }
    </style>
</head>
<body>

<h1 style="text-align:center;">FreeStream</h1>

<div class="grid" id="grid"></div>

<script>
async function load() {
    const res = await fetch('/movies');
    const movies = await res.json();

    const grid = document.getElementById('grid');

    movies.forEach(file => {
        const div = document.createElement('div');
        div.className = 'item';
        div.innerText = file;

        div.onclick = () => {
            fetch(`/play?file=${encodeURIComponent(file)}`);
        };

        grid.appendChild(div);
    });
}

load();
</script>

</body>
</html>
